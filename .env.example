# Required — your Sitecore Search (Discover) API key
# Find this in your Sitecore Search dashboard or .env file
# It starts with 01-
SITECORE_SEARCH_API_KEY=your-01-prefixed-api-key-here

# Optional — Microsoft Teams webhook URL for alerts
# How to get this: Teams → channel → Workflows →
# "Send webhook alerts to a channel"
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/...

# Optional — override output directory (default: ./output)
OUTPUT_DIR=./output
